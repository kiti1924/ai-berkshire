{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fact",
  "type": "object",
  "required": [
    "fact_id",
    "security_id",
    "metric",
    "value",
    "retrieved_at",
    "source_url",
    "source_rank",
    "consolidation",
    "fact_type",
    "verification_status"
  ],
  "properties": {
    "fact_id": { "type": "string" },
    "security_id": { "type": "string" },
    "metric": { "type": "string" },
    "value": { "type": ["number", "string", "boolean"] },
    "unit": { "type": ["string", "null"] },
    "currency": { "type": ["string", "null"] },
    "period_start": { "type": ["string", "null"] },
    "period_end": { "type": ["string", "null"] },
    "as_of": { "type": ["string", "null"] },
    "retrieved_at": { "type": "string" },
    "source_document_id": { "type": ["string", "null"] },
    "source_url": { "type": "string" },
    "source_rank": { "type": "integer" },
    "accounting_standard": { "type": ["string", "null"] },
    "consolidation": { "type": "string", "enum": ["consolidated", "standalone", "unknown"] },
    "fact_type": { "type": "string", "enum": ["reported", "forecast", "estimate", "normalized"] },
    "verification_status": { "type": "string", "enum": ["unverified", "single_source", "cross_checked", "official"] }
  },
  "additionalProperties": false
}
